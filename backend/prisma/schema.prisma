generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== SPRAWDZANY POJAZD ==========
model CheckedVehicle {
  id              Int      @id @default(autoincrement())
  vehicleType     String   @db.VarChar(50)  // Auto, Motocykl, Bus, Ciezarowy, Kamper
  make            String   @db.VarChar(100)
  model           String   @db.VarChar(100)
  year            Int
  bodyType        String?  @db.VarChar(50)
  fuelType        String?  @db.VarChar(50)
  color           String?  @db.VarChar(50)
  transmission    String?  @db.VarChar(50)  // Manualna, Automatyczna, Zautomatyzowana (N/D dla motocykli)
  engineCode      String?  @db.VarChar(100)
  engineFamily    String?  @db.VarChar(100)
  engineCapacity  Float?
  horsepowerKM    Float?
  horsepowerKW    Float?
  torque          Float?
  pricePLN        Float?
  priceUSD        Float?
  priceEUR        Float?
  currency        String   @default("PLN") @db.VarChar(10)
  mileageKm       Float?
  mileageMi       Float?
  accidentFree    Boolean  @default(true)
  damaged         Boolean  @default(false)
  damageDescription String? @db.Text
  continent       String?  @db.VarChar(100)
  country         String?  @db.VarChar(100)
  notes           String?  @db.Text
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  marketOffers    MarketOffer[]
}

// ========== OFERTA RYNKOWA ==========
model MarketOffer {
  id              Int      @id @default(autoincrement())
  checkedVehicleId Int?
  checkedVehicle  CheckedVehicle? @relation(fields: [checkedVehicleId], references: [id])
  vehicleType     String   @db.VarChar(50)
  make            String   @db.VarChar(100)
  model           String   @db.VarChar(100)
  year            Int
  bodyType        String?  @db.VarChar(50)
  fuelType        String?  @db.VarChar(50)
  color           String?  @db.VarChar(50)
  transmission    String?  @db.VarChar(50)
  engineCode      String?  @db.VarChar(100)
  engineFamily    String?  @db.VarChar(100)
  engineCapacity  Float?
  horsepowerKM    Float?
  horsepowerKW    Float?
  torque          Float?
  pricePLN        Float?
  priceUSD        Float?
  priceEUR        Float?
  currency        String   @default("PLN") @db.VarChar(10)
  mileageKm       Float?
  mileageMi       Float?
  accidentFree    Boolean  @default(true)
  damaged         Boolean  @default(false)
  damageDescription String? @db.Text
  continent       String?  @db.VarChar(100)
  country         String?  @db.VarChar(100)
  offerUrl        String?  @db.VarChar(500)
  equipment       String?  @db.Text
  notes           String?  @db.Text
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ========== USTAWIENIA ==========
model Settings {
  id                    Int      @id @default(autoincrement())
  exciseDutySmall       Float    @default(3.1)   // akcyza <= 2.0l (%)
  exciseDutyLarge       Float    @default(18.6)  // akcyza > 2.0l (%)
  customsDuty           Float    @default(10)    // clo (%)
  incomeTax             Float    @default(19)    // podatek dochodowy (%)
  vat                   Float    @default(23)    // VAT (%)
  estimatedRepairCost   Float    @default(0)     // szacowane koszty napraw
  desiredMargin         Float    @default(0)     // pozadana marza
  transportCost         Float    @default(0)     // koszt transportu
  registrationCost      Float    @default(0)     // koszt rejestracji
  expertCost            Float    @default(0)     // koszt rzeczoznawcy
  isArchived            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
